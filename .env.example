# Environment variables for VideoMax MBA.
# Duplicate this file to .env.local and fill values as features add them.

# F02 (Authentication System)
# Local Postgres from docker-compose.yml (host port 5433).
DATABASE_URL="postgresql://videomax:videomax@localhost:5433/videomax"
# Secret used to sign the session cookie. Use at least 32 random bytes in real envs.
SESSION_SECRET="change-me-to-at-least-32-random-bytes"

# F03 (Video Upload)
# Root directory (relative to the project, or absolute) where uploaded video
# files and their thumbnails are stored. Gitignored via /storage/.
VIDEO_STORAGE_ROOT="storage/videos"
# Maximum accepted upload size in bytes. Default is 2 GiB (2 * 1024^3).
VIDEO_MAX_BYTES="2147483648"
